{
  "openapi": "3.0.0",
  "info": {
    "title": "Arsenal FC Assistant Tools",
    "version": "1.0.0",
    "description": "Action group for the Arsenal FC AI Assistant powered by Bedrock Agent Core"
  },
  "paths": {
    "/GetFixtures": {
      "get": {
        "operationId": "GetFixtures",
        "summary": "Get Arsenal's upcoming and recent match fixtures with scores",
        "description": "Returns Arsenal FC's scheduled and completed matches across ALL competitions, sorted chronologically. The first result is always the chronologically nearest match. Each match includes the competition name so you can answer competition-specific questions from the full list. Use type=upcoming for next matches, type=recent for past results.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Number of matches to return (default 10, max 20)",
            "required": false,
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter type: 'upcoming' for scheduled/timed matches only, 'recent' for finished matches only, 'all' for both.",
            "required": false,
            "schema": { "type": "string", "default": "upcoming", "enum": ["upcoming", "recent", "all"] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of Arsenal matches",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "matches": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "home": { "type": "string" },
                          "away": { "type": "string" },
                          "date": { "type": "string" },
                          "status": { "type": "string" },
                          "score": { "type": "string" },
                          "competition": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/GetStandings": {
      "get": {
        "operationId": "GetStandings",
        "summary": "Get league standings table",
        "description": "Returns the full league standings table with position, points, wins, draws, losses, and goal difference. Use this when the user asks about league position, table, points, or how teams compare.",
        "parameters": [
          {
            "name": "league",
            "in": "query",
            "description": "League code: PL (Premier League), CL (Champions League), PD (La Liga), BL1 (Bundesliga), SA (Serie A), FL1 (Ligue 1)",
            "required": false,
            "schema": { "type": "string", "default": "PL" }
          }
        ],
        "responses": {
          "200": {
            "description": "League standings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "league": { "type": "string" },
                    "table": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "position": { "type": "integer" },
                          "team": { "type": "string" },
                          "played": { "type": "integer" },
                          "won": { "type": "integer" },
                          "drawn": { "type": "integer" },
                          "lost": { "type": "integer" },
                          "points": { "type": "integer" },
                          "gd": { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/GetLiveScore": {
      "get": {
        "operationId": "GetLiveScore",
        "summary": "Get current live Arsenal match score",
        "description": "Returns the current live score if Arsenal is playing right now. Use this when the user asks about a live match, current score, or what's happening right now.",
        "responses": {
          "200": {
            "description": "Live match data or no-match indicator",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "live": { "type": "boolean" },
                    "home": { "type": "string" },
                    "away": { "type": "string" },
                    "homeScore": { "type": "integer" },
                    "awayScore": { "type": "integer" },
                    "minute": { "type": "integer" },
                    "competition": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/GetSquad": {
      "get": {
        "operationId": "GetSquad",
        "summary": "Get Arsenal's current squad and coach",
        "description": "Returns the full Arsenal squad with player names, positions, nationalities, and shirt numbers. Use this when the user asks about players, squad, team roster, or specific player info.",
        "responses": {
          "200": {
            "description": "Squad data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "team": { "type": "string" },
                    "coach": { "type": "string" },
                    "squad": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "position": { "type": "string" },
                          "nationality": { "type": "string" },
                          "number": { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/GetScorers": {
      "get": {
        "operationId": "GetScorers",
        "summary": "Get top scorers in a league, including Arsenal's scorers",
        "description": "Returns the top 20 goal scorers in a competition. Also returns arsenalTopScorer (Arsenal's highest-ranked scorer) and arsenalScorers (all Arsenal players in the top 20). Use this when the user asks about top scorers, golden boot, who has the most goals, or Arsenal's top scorer.",
        "parameters": [
          {
            "name": "league",
            "in": "query",
            "description": "League code: PL (Premier League), CL (Champions League). Default PL.",
            "required": false,
            "schema": { "type": "string", "default": "PL" }
          }
        ],
        "responses": {
          "200": {
            "description": "Top scorers list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "competition": { "type": "string" },
                    "arsenalTopScorer": { "type": "object", "nullable": true, "description": "Arsenal's highest-ranked scorer, or null if none in top 20" },
                    "arsenalScorers": { "type": "array", "items": { "type": "object" }, "description": "All Arsenal players in the top 20" },
                    "scorers": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "player": { "type": "string" },
                          "team": { "type": "string" },
                          "goals": { "type": "integer" },
                          "assists": { "type": "integer" },
                          "penalties": { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/GetNews": {
      "get": {
        "operationId": "GetNews",
        "summary": "Get latest Arsenal FC news articles",
        "description": "Returns the latest Arsenal news headlines with source and links. Use this when the user asks about news, transfers, rumors, or what's happening with Arsenal off the pitch.",
        "responses": {
          "200": {
            "description": "News articles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "articles": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "title": { "type": "string" },
                          "description": { "type": "string" },
                          "source": { "type": "string" },
                          "date": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/GetPrediction": {
      "get": {
        "operationId": "GetPrediction",
        "summary": "Get upcoming match data and recent form for a prediction",
        "description": "Returns the next Arsenal match details and last 5 results. Use this when the user asks for a prediction, who will win, or what to expect from a match.",
        "responses": {
          "200": {
            "description": "Next match and recent form data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "nextMatch": { "type": "object" },
                    "arsenalRecentForm": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/GetMatchSummary": {
      "get": {
        "operationId": "GetMatchSummary",
        "summary": "Get the most recent Arsenal match result with standings context",
        "description": "Returns the latest completed match result plus current PL standings including exact games remaining per team. Use top5Standings.gamesRemaining when mentioning remaining games — never estimate.",
        "responses": {
          "200": {
            "description": "Match result and standings context",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": { "type": "object" },
                    "arsenalStandings": { "type": "object", "nullable": true },
                    "top5Standings": { "type": "array", "items": { "type": "object" }, "description": "Top 5 teams with exact gamesRemaining per team" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/GetHeadToHead": {
      "get": {
        "operationId": "GetHeadToHead",
        "summary": "Get Arsenal's results against a specific opponent this season",
        "description": "Returns all finished Arsenal matches against a specific opponent this season with scores and competition. Use this when the user asks how Arsenal did against a specific team, for head-to-head records, or 'how did we do vs X'.",
        "parameters": [
          {
            "name": "opponent",
            "in": "query",
            "description": "Opponent team name or partial name (e.g. 'Manchester City', 'Man City', 'Chelsea', 'Atletico')",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Head-to-head results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "matches": { "type": "array", "items": { "type": "object" } },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
